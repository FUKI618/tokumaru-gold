---
interface Props {
  title: string;
  description: string;
  extraJsonLd?: Record<string, unknown>[];
}

import "../styles/global.css";
import { assetPath, homePath } from "../lib/site";
import { faqsToJsonLd } from "../data/faq";
import { company } from "../data/company";

const { title, description, extraJsonLd = [] } = Astro.props;
const canonicalUrl = Astro.url.href;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const homeUrl = new URL(homePath, siteUrl).toString();
const ogImage = new URL(assetPath("og-image.webp"), siteUrl).toString();
const faviconUrl = assetPath("favicon.svg");
const logoUrl = new URL(assetPath("logo.svg"), siteUrl).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="keywords" content="金買取,名古屋,ブランド品買取,貴金属買取,金相場,プラチナ買取,ジュエリー買取,エルメス買取,シャネル買取,出張買取" />
    <meta name="theme-color" content="#1a1a2e" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://googleads.g.doubleclick.net https://www.google.com https://www.google-analytics.com https://www.googleadservices.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://www.google.com https://googleads.g.doubleclick.net https://www.googleadservices.com https://www.google-analytics.com https://www.google.co.jp; connect-src 'self' https://www.google-analytics.com https://www.google.com https://googleads.g.doubleclick.net https://analytics.google.com https://fonts.googleapis.com https://fonts.gstatic.com https://region1.google-analytics.com; frame-src https://www.googletagmanager.com https://googleads.g.doubleclick.net" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="徳丸商会の金・ブランド品買取。名古屋で金・プラチナ・エルメス・シャネルを高価買取。" />
    <meta property="og:site_name" content="徳丸商会｜名古屋の金・ブランド品買取" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="徳丸商会の金・ブランド品買取。名古屋で金・プラチナ・エルメス・シャネルを高価買取。" />

    <!-- LCP Hero画像のプリロード -->
    <link rel="preload" as="image" type="image/webp" href={assetPath("images/gold/hero.webp")} fetchpriority="high" />

    <!-- Fonts: JS非同期読み込み -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      (function(){
        var l=document.createElement('link');l.rel='stylesheet';
        l.href='https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap';
        document.head.appendChild(l);
      })();
    </script>

    <!-- Google Tag Manager: 3秒遅延 -->
    <script is:inline>
      window.dataLayer=window.dataLayer||[];
      setTimeout(function(){
        (function(w,d,s,l,i){w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
        var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
        j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
        f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-W493L98W');
      },3000);
    </script>

    <!-- JSON-LD: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": `${homeUrl}#localbusiness`,
      "name": "徳丸商会",
      "description": "名古屋市・近郊エリアの金・貴金属・ブランド品買取。金・プラチナ・シルバーを毎日更新の相場で高価買取。エルメス・シャネル・ルイヴィトンなどブランド品も専門査定。出張費・査定費0円。",
      "telephone": company.phone,
      "url": homeUrl,
      "image": ogImage,
      "priceRange": "$$",
      "openingHours": "Mo-Su 09:00-21:00",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": company.address.locality,
        "addressRegion": company.address.region,
        "addressCountry": company.address.country
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "35.1709",
        "longitude": "136.8815"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "387",
        "bestRating": "5"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "telephone": company.phone,
        "availableLanguage": ["ja"],
        "areaServed": "JP"
      },
      "areaServed": [
        { "@type": "City", "name": "名古屋市", "containedInPlace": { "@type": "State", "name": "愛知県" } },
        ...company.nearby.map(city => ({ "@type": "City", "name": city }))
      ],
      "sameAs": [company.line],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "金・ブランド品買取サービス",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "金・K24純金の買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "プラチナ製品の買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "シルバー製品の買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ダイヤモンド・宝石の買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランドバッグの買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランド時計の買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ブランドジュエリーの買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "金貨・インゴットの買取" } }
        ]
      }
    })} />

    <!-- JSON-LD: FAQPage -->
    <script type="application/ld+json" set:html={JSON.stringify(faqsToJsonLd())} />

    <!-- JSON-LD: HowTo -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "名古屋で金・ブランド品の出張買取を依頼する方法",
      "description": "徳丸商会の出張買取サービスを利用する手順です。お電話またはLINEでのお問い合わせから、訪問査定、現金お支払いまでかんたん3ステップで完了します。",
      "totalTime": "PT1H",
      "estimatedCost": { "@type": "MonetaryAmount", "currency": "JPY", "value": "0" },
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "お電話・LINEでお問い合わせ", "text": "買取希望のお品物や訪問日時をお伝えください。LINEなら写真を送るだけで事前査定も可能です。052-990-3968まで。" },
        { "@type": "HowToStep", "position": 2, "name": "ご訪問・査定・現金払い", "text": "査定員がご自宅にお伺いし、金の品位測定やブランド品の真贋鑑定を行います。金額にご納得いただければ、その場で現金をお渡しします。" },
        { "@type": "HowToStep", "position": 3, "name": "お品物のお引き取り", "text": "買取成立したお品物をお引き取りします。キャンセル料は一切かかりません。" }
      ]
    })} />

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "徳丸商会",
      "url": homeUrl,
      "logo": logoUrl,
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": company.phone,
        "contactType": "customer support",
        "availableLanguage": "ja",
        "areaServed": "JP"
      }
    })} />

    {extraJsonLd.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body class="antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W493L98W"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <slot />

    <!-- Alpine.js -->
    <script>
      import Alpine from "alpinejs";
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
