---
import Layout from "../layouts/Layout.astro";
import { homePath, assetPath } from "../lib/site";
import { goldPrice } from "../data/goldPrice";
import { company } from "../data/company";

const logo = assetPath("logo.svg");
const updated = new Date(goldPrice.lastUpdated);
const updatedStr = `${updated.getFullYear()}年${updated.getMonth() + 1}月${updated.getDate()}日`;

// ビルド時に価格データを埋め込む
const priceData = {
  gold: {
    k24: goldPrice.gold.k24,
    k22: goldPrice.gold.k22,
    k18: goldPrice.gold.k18,
    k14: goldPrice.gold.k14,
    k10: goldPrice.gold.k10,
  },
  platinum: {
    pt1000: goldPrice.platinum.pt1000,
    pt950: goldPrice.platinum.pt950,
    pt900: goldPrice.platinum.pt900,
    pt850: goldPrice.platinum.pt850,
  },
  silver: {
    sv1000: goldPrice.silver.sv1000,
    sv925: goldPrice.silver.sv925,
  },
};
---

<Layout
  title="金・貴金属 買取金額シミュレーション｜徳丸商会"
  description="金・プラチナ・シルバーの買取金額をその場で簡単計算。K24・K18・Pt950など品位を選んで重量を入力するだけ。名古屋の金・貴金属買取専門店 徳丸商会の公式シミュレーター。"
>

<!-- ヘッダー -->
<div class="hidden md:block fixed top-0 inset-x-0 z-50 bg-dark border-b border-gold/10">
  <div class="max-w-6xl mx-auto px-5 h-8 flex items-center justify-end gap-6 text-[11px] text-white/50">
    <span>受付 {company.hours}</span>
    <a href={`tel:${company.phone}`} class="flex items-center gap-1 text-white/70 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {company.phone}
    </a>
  </div>
</div>

<header class="fixed top-0 md:top-8 inset-x-0 z-50 bg-dark/95 backdrop-blur-md shadow-2xl border-b border-gold/15">
  <div class="max-w-6xl mx-auto px-4 md:px-5 h-[72px] md:h-[92px] flex items-center justify-between">
    <a href={homePath} class="flex items-center gap-3 group">
      <img src={logo} alt="徳丸商会" width="56" height="56" class="w-[58px] h-[58px] md:w-[72px] md:h-[72px] transition-transform group-hover:scale-105" />
      <div class="flex flex-col">
        <span class="text-white font-black text-xl md:text-2xl leading-tight tracking-tight">徳丸商会</span>
        <span class="text-gold/80 text-[9px] md:text-xs font-bold leading-tight whitespace-nowrap">金・ブランド品買取専門</span>
      </div>
    </a>
    <a href={homePath} class="hidden md:flex items-center gap-1.5 text-white/60 hover:text-white text-sm font-bold transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      トップページに戻る
    </a>
    <div class="flex items-center gap-2 md:hidden">
      <a href={`tel:${company.phone}`} class="flex items-center justify-center gap-1.5 bg-gold hover:bg-gold-light text-dark font-bold text-[11px] px-3 py-2 rounded-lg transition-colors shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        電話
      </a>
      <a href={company.line} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-1.5 bg-line hover:brightness-110 text-white font-bold text-[11px] px-3 py-2 rounded-lg transition-all shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
        LINE
      </a>
    </div>
  </div>
</header>

<main class="pt-[72px] md:pt-[124px] min-h-screen bg-bg">

  <!-- ページタイトル -->
  <section class="bg-dark py-10 md:py-14">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <p class="text-gold/70 text-xs md:text-sm font-bold tracking-widest uppercase mb-2">Simulation</p>
      <h1 class="text-white font-black text-2xl md:text-4xl leading-tight">
        金・貴金属 買取金額<br class="md:hidden" />シミュレーション
      </h1>
      <p class="text-white/50 text-xs md:text-sm mt-3">
        相場日付: <span class="text-gold/80">{updatedStr}</span>
        &nbsp;|&nbsp; 価格は参考価格です
      </p>
    </div>
  </section>

  <!-- シミュレーター本体 -->
  <section class="py-10 md:py-14">
    <div class="max-w-2xl mx-auto px-4 md:px-5">

      <div
        x-data={`simulationApp(${JSON.stringify(priceData)})`}
        class="bg-white rounded-2xl shadow-xl border border-border overflow-hidden"
      >
        <!-- カテゴリタブ -->
        <div class="flex border-b border-border">
          <button
            x-on:click="setCategory('gold')"
            x-bind:class="category === 'gold' ? 'bg-gold text-dark font-black border-b-2 border-gold' : 'text-text-light hover:bg-gold-bg hover:text-text'"
            class="flex-1 py-4 text-sm md:text-base font-bold transition-colors"
          >
            金（ゴールド）
          </button>
          <button
            x-on:click="setCategory('platinum')"
            x-bind:class="category === 'platinum' ? 'bg-gold text-dark font-black border-b-2 border-gold' : 'text-text-light hover:bg-gold-bg hover:text-text'"
            class="flex-1 py-4 text-sm md:text-base font-bold transition-colors"
          >
            プラチナ
          </button>
          <button
            x-on:click="setCategory('silver')"
            x-bind:class="category === 'silver' ? 'bg-gold text-dark font-black border-b-2 border-gold' : 'text-text-light hover:bg-gold-bg hover:text-text'"
            class="flex-1 py-4 text-sm md:text-base font-bold transition-colors"
          >
            シルバー
          </button>
        </div>

        <div class="p-6 md:p-8 space-y-7">

          <!-- 品位ボタン群 -->
          <div>
            <p class="text-xs font-bold text-text-light uppercase tracking-widest mb-3">品位を選択</p>

            <!-- 金 -->
            <div x-show="category === 'gold'" class="flex flex-wrap gap-2">
              <template x-for="grade in grades.gold" :key="grade.key">
                <button
                  x-on:click="setGrade(grade)"
                  x-bind:class="selectedGrade && selectedGrade.key === grade.key ? 'bg-dark text-white border-dark' : 'bg-white text-text border-border hover:border-gold hover:text-gold'"
                  class="px-4 py-2.5 rounded-xl border-2 text-sm font-bold transition-all"
                  x-text="grade.label"
                ></button>
              </template>
            </div>

            <!-- プラチナ -->
            <div x-show="category === 'platinum'" class="flex flex-wrap gap-2">
              <template x-for="grade in grades.platinum" :key="grade.key">
                <button
                  x-on:click="setGrade(grade)"
                  x-bind:class="selectedGrade && selectedGrade.key === grade.key ? 'bg-dark text-white border-dark' : 'bg-white text-text border-border hover:border-gold hover:text-gold'"
                  class="px-4 py-2.5 rounded-xl border-2 text-sm font-bold transition-all"
                  x-text="grade.label"
                ></button>
              </template>
            </div>

            <!-- シルバー -->
            <div x-show="category === 'silver'" class="flex flex-wrap gap-2">
              <template x-for="grade in grades.silver" :key="grade.key">
                <button
                  x-on:click="setGrade(grade)"
                  x-bind:class="selectedGrade && selectedGrade.key === grade.key ? 'bg-dark text-white border-dark' : 'bg-white text-text border-border hover:border-gold hover:text-gold'"
                  class="px-4 py-2.5 rounded-xl border-2 text-sm font-bold transition-all"
                  x-text="grade.label"
                ></button>
              </template>
            </div>

            <!-- 選択中の単価表示 -->
            <p x-show="selectedGrade" class="mt-3 text-xs text-text-lighter">
              <span x-text="selectedGrade ? selectedGrade.label : ''"></span>:
              <span class="text-gold font-bold" x-text="selectedGrade ? selectedGrade.unitPrice.toLocaleString('ja-JP') + '円/g' : ''"></span>
            </p>
          </div>

          <!-- 重量入力 -->
          <div>
            <label class="block text-xs font-bold text-text-light uppercase tracking-widest mb-3" for="weight-input">
              重量（グラム）
            </label>
            <div class="flex items-center gap-3">
              <input
                id="weight-input"
                type="number"
                min="0.1"
                max="9999"
                step="0.1"
                x-model="weight"
                x-on:input="calculate()"
                placeholder="例: 10.5"
                class="flex-1 border-2 border-border rounded-xl px-4 py-3.5 text-lg font-bold text-text focus:outline-none focus:border-gold transition-colors placeholder:text-text-lighter placeholder:font-normal"
              />
              <span class="text-text-light font-bold text-sm">g</span>
            </div>
            <p class="mt-2 text-xs text-text-lighter">小数点第1位まで入力できます（例: 5.3g）</p>
          </div>

          <!-- 計算ボタン -->
          <button
            x-on:click="calculate()"
            x-bind:disabled="!selectedGrade || !weight || weight <= 0"
            x-bind:class="(!selectedGrade || !weight || weight <= 0) ? 'opacity-40 cursor-not-allowed' : 'hover:bg-gold-light active:scale-95'"
            class="w-full bg-gold text-dark font-black text-base md:text-lg py-4 rounded-xl transition-all shadow-md"
          >
            計算する
          </button>

          <!-- 結果表示 -->
          <div
            x-show="result !== null"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100"
            class="bg-gold-bg border-2 border-gold/30 rounded-2xl p-6 text-center"
          >
            <p class="text-xs font-bold text-text-light uppercase tracking-widest mb-1">概算買取金額</p>
            <p class="text-4xl md:text-5xl font-black text-dark mt-2 mb-1">
              <span class="text-gold" x-text="result !== null ? result.toLocaleString('ja-JP') : ''"></span>
              <span class="text-lg text-text-light font-bold ml-1">円</span>
            </p>
            <p class="text-xs text-text-lighter mt-2">
              <span x-text="selectedGrade ? selectedGrade.label : ''"></span>
              &nbsp;×&nbsp;
              <span x-text="parseFloat(weight).toFixed(1)"></span>g
              &nbsp;×&nbsp;
              <span x-text="selectedGrade ? selectedGrade.unitPrice.toLocaleString('ja-JP') : ''"></span>円/g
            </p>
          </div>

          <!-- 初期状態メッセージ -->
          <div
            x-show="result === null"
            class="bg-bg rounded-2xl border-2 border-dashed border-border p-8 text-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-3 text-border" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
            </svg>
            <p class="text-sm text-text-lighter">品位と重量を選択・入力して<br />「計算する」ボタンを押してください</p>
          </div>

        </div>
      </div>

      <!-- 注意書き -->
      <div class="mt-6 bg-white rounded-xl border border-border p-5 space-y-2">
        <p class="text-[11px] md:text-xs text-text-lighter leading-relaxed">
          ※シミュレーション結果は参考価格です。実際の買取価格は査定時に決定します。
        </p>
        <p class="text-[11px] md:text-xs text-text-lighter leading-relaxed">
          ※宝石やデザイン性の価値は含まれていません。実物を拝見して加算いたします。
        </p>
        <p class="text-[11px] md:text-xs text-text-lighter leading-relaxed">
          ※金・貴金属の相場は日々変動します。表示金額は {updatedStr} 時点の参考相場に基づきます。
        </p>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-16 bg-dark">
    <div class="max-w-2xl mx-auto px-5 text-center">
      <p class="text-gold/70 text-xs font-bold tracking-widest uppercase mb-3">Free Assessment</p>
      <h2 class="text-white font-black text-2xl md:text-3xl mb-3">無料査定を申し込む</h2>
      <p class="text-white/60 text-sm mb-8">出張費・査定費は0円。キャンセルも無料です。</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={`tel:${company.phone}`}
          class="flex items-center justify-center gap-2.5 bg-gold hover:bg-gold-light text-dark font-black text-base md:text-lg px-8 py-4 rounded-xl transition-colors shadow-xl"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {company.phone}
        </a>
        <a
          href={company.line}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2.5 bg-line hover:brightness-110 text-white font-black text-base md:text-lg px-8 py-4 rounded-xl transition-all shadow-xl"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          LINEで無料査定
        </a>
      </div>
      <p class="text-white/40 text-xs mt-5">受付時間: {company.hours}</p>
    </div>
  </section>

  <!-- フッター -->
  <footer class="bg-dark-dark border-t border-white/5 py-8">
    <div class="max-w-6xl mx-auto px-5 text-center space-y-2">
      <p class="text-white/60 text-sm font-bold">徳丸商会</p>
      <p class="text-white/30 text-xs">{company.license}</p>
      <a href={homePath} class="inline-block text-gold/60 hover:text-gold text-xs transition-colors mt-1">
        トップページに戻る
      </a>
    </div>
  </footer>

</main>

<script define:vars={{ priceData }}>
  function simulationApp(prices) {
    return {
      category: "gold",
      selectedGrade: null,
      weight: "",
      result: null,

      grades: {
        gold: [
          { key: "k24", label: "K24（純金）", unitPrice: prices.gold.k24 },
          { key: "k22", label: "K22", unitPrice: prices.gold.k22 },
          { key: "k18", label: "K18", unitPrice: prices.gold.k18 },
          { key: "k14", label: "K14", unitPrice: prices.gold.k14 },
          { key: "k10", label: "K10", unitPrice: prices.gold.k10 },
        ],
        platinum: [
          { key: "pt1000", label: "Pt1000（純プラチナ）", unitPrice: prices.platinum.pt1000 },
          { key: "pt950", label: "Pt950", unitPrice: prices.platinum.pt950 },
          { key: "pt900", label: "Pt900", unitPrice: prices.platinum.pt900 },
          { key: "pt850", label: "Pt850", unitPrice: prices.platinum.pt850 },
        ],
        silver: [
          { key: "sv1000", label: "Sv1000（純銀）", unitPrice: prices.silver.sv1000 },
          { key: "sv925", label: "Sv925（スターリング）", unitPrice: prices.silver.sv925 },
        ],
      },

      setCategory(cat) {
        this.category = cat;
        this.selectedGrade = null;
        this.result = null;
      },

      setGrade(grade) {
        this.selectedGrade = grade;
        this.calculate();
      },

      calculate() {
        if (!this.selectedGrade) return;
        const w = parseFloat(this.weight);
        if (!w || w <= 0) {
          this.result = null;
          return;
        }
        const raw = w * this.selectedGrade.unitPrice;
        this.result = Math.floor(raw);
      },
    };
  }

  window.simulationApp = simulationApp;
</script>

</Layout>
