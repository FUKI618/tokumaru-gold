<script is:inline>
(function () {
  function initReveal() {
    var els = document.querySelectorAll('.reveal');
    if (!els.length) return;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    els.forEach(function (el) { io.observe(el); });
  }
  function animateCount(el, target, duration) {
    var startTime = null;
    function step(timestamp) {
      if (!startTime) startTime = timestamp;
      var progress = Math.min((timestamp - startTime) / duration, 1);
      var eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(eased * target).toLocaleString('ja-JP');
      if (progress < 1) requestAnimationFrame(step);
      else el.textContent = target.toLocaleString('ja-JP');
    }
    requestAnimationFrame(step);
  }
  function initCountUp() {
    var els = document.querySelectorAll('.count-up[data-target]');
    if (!els.length) return;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          animateCount(entry.target, parseInt(entry.target.dataset.target, 10), 1800);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });
    els.forEach(function (el) { io.observe(el); });
  }
  window.addEventListener('load', function () {
    setTimeout(function () { document.documentElement.classList.add('scroll-ready'); }, 500);
  });
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initReveal(); initCountUp(); });
  } else {
    initReveal(); initCountUp();
  }
})();

// === 金相場 動的更新 ===
// goldPrice.json をfetchして、ページ内の金額表示をリアルタイムに更新
(function(){
  // GitHub Pagesから最新の金相場JSONを取得（毎朝9時に自動更新される）
  var ghPagesUrl = 'https://fuki618.github.io/tokumaru-gold/goldPrice.json';
  var localUrl = '/goldPrice.json';

  // まずGitHub Pages（常に最新）→ ダメならローカル（アップ時の値）
  fetch(ghPagesUrl).then(function(r){ return r.ok ? r.json() : Promise.reject(); }).then(updatePrices).catch(function(){
    fetch(localUrl).then(function(r){ return r.ok ? r.json() : Promise.reject(); }).then(updatePrices).catch(function(){
      console.log('[金相場] JSONの取得に失敗。ビルド時の値を表示します。');
    });
  });

  function fmt(n) { return n.toLocaleString('ja-JP'); }

  function updatePrices(data) {
    if (!data || !data.gold) return;

    // ヒーロー K24 金額
    var heroK24 = document.querySelectorAll('[data-gp="hero-k24"]');
    heroK24.forEach(function(el){ el.textContent = '¥' + fmt(data.gold.tanakaBuy); });

    // ヒーロー K18
    var heroK18 = document.querySelectorAll('[data-gp="hero-k18"]');
    heroK18.forEach(function(el){ el.textContent = 'K18: ¥' + fmt(data.gold.market.k18) + '/g'; });

    // 更新日
    var d = new Date(data.lastUpdated);
    var dateStr = d.getFullYear() + '年' + (d.getMonth()+1) + '月' + d.getDate() + '日';
    var dateEls = document.querySelectorAll('[data-gp="date"]');
    dateEls.forEach(function(el){ el.textContent = dateStr; });

    // 金相場テーブルの各行
    var gradeKeys = ['k24','k23','k22','k21_6','k20','k18','k17','k14','k12','k10','k9','k8','k7','k5'];
    gradeKeys.forEach(function(key){
      var el = document.querySelector('[data-gp="gold-' + key + '"]');
      if (el && data.gold.market[key]) {
        el.textContent = fmt(data.gold.market[key]) + '円';
      }
    });

    // インゴットとK24は tanakaBuy そのもの
    var ingot = document.querySelector('[data-gp="gold-ingot"]');
    if (ingot) ingot.textContent = fmt(data.gold.tanakaBuy) + '円';
    var k24Direct = document.querySelector('[data-gp="gold-k24-direct"]');
    if (k24Direct) k24Direct.textContent = fmt(data.gold.tanakaBuy) + '円';

    // プラチナ
    ['pt1000','pt950','pt900','pt850'].forEach(function(key){
      var el = document.querySelector('[data-gp="pt-' + key + '"]');
      if (el && data.platinum.market[key]) {
        el.textContent = fmt(data.platinum.market[key]) + '円';
      }
    });

    // シルバー
    ['sv1000','sv925'].forEach(function(key){
      var el = document.querySelector('[data-gp="sv-' + key + '"]');
      if (el && data.silver.market[key]) {
        el.textContent = fmt(data.silver.market[key]) + '円';
      }
    });

    console.log('[金相場] 動的更新完了: K24=' + fmt(data.gold.tanakaBuy) + '円/g (' + dateStr + ')');
  }
})();
</script>

