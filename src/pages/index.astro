// ブランド買取実績画像
const resultBrandBirkin = assetPath("images/gold/result-brand-birkin.webp");
const resultBrandChanel = assetPath("images/gold/result-brand-chanel.webp");
const resultBrandLV = assetPath("images/gold/result-brand-lv.webp");
const resultBrandRolex = assetPath("images/gold/result-brand-rolex.webp");

// 金相場表示用フォーマット
const fmt = (n: number) => n.toLocaleString("ja-JP");
const updated = new Date(goldPrice.lastUpdated);
const updatedStr = `${updated.getFullYear()}年${updated.getMonth()+1}月${updated.getDate()}日`;

// 金の品位テーブル
const goldGrades = [
  { label: "インゴット(金)", key: "k24", purity: "99.9%" },
  { label: "24金(K24・純金)", key: "k24", purity: "99.9%" },
  { label: "23金(K23)", key: "k23", purity: "95.8%" },
  { label: "22金(K22)", key: "k22", purity: "91.7%" },
  { label: "21.6金(K21.6)", key: "k21_6", purity: "90.0%" },
  { label: "20金(K20)", key: "k20", purity: "83.3%" },
  { label: "18金(K18)", key: "k18", purity: "75.0%" },
  { label: "14金(K14)", key: "k14", purity: "58.5%" },
  { label: "10金(K10)", key: "k10", purity: "41.7%" },
  { label: "9金(K9)", key: "k9", purity: "37.5%" },
];

const ptGrades = [
  { label: "Pt1000(純プラチナ)", price: goldPrice.platinum.market.pt1000 },
  { label: "Pt950", price: goldPrice.platinum.market.pt950 },
  { label: "Pt900", price: goldPrice.platinum.market.pt900 },
  { label: "Pt850", price: goldPrice.platinum.market.pt850 },
];

// 金・貴金属の買取実績
const goldResults = [
  { name: "K24 喜平ネックレス 50g", price: "1,225,000", img: resultNecklace, area: "名古屋市中区", who: "60代女性 S.K様", reason: "相続で譲り受けたが使う機会がなく売却。金相場高騰のタイミングで高額査定に。" },
  { name: "K18 ダイヤリング", price: "86,000", img: resultRing, area: "名古屋市千種区", who: "40代女性 M.T様", reason: "サイズが合わなくなった指輪。ダイヤの品質も加味して査定。" },
  { name: "Pt900 サファイアリング", price: "124,000", img: resultPtRing, area: "名古屋市名東区", who: "70代女性 H.N様", reason: "母から譲り受けたプラチナリング。宝石の価値も含めて査定。" },
  { name: "K18 ブレスレット 30g", price: "551,000", img: resultBracelet, area: "名古屋市緑区", who: "50代男性 Y.A様", reason: "使わなくなったブレスレットをまとめて売却。重量があり高額に。" },
  { name: "メイプルリーフ金貨 1oz", price: "396,000", img: resultCoin, area: "あま市", who: "60代男性 K.M様", reason: "コレクションの金貨を整理。純金1オンスで相場通りの査定。" },
  { name: "金インゴット 100g×3", price: "7,353,000", img: resultIngot, area: "名古屋市中村区", who: "70代男性 T.S様", reason: "資産整理のため売却。大口のため出張買取で対応。" },
];


// 状態例
const conditions = [
  { img: condDeformed, label: "変形・ちぎれ", desc: "曲がった金アクセサリーも買取OK" },
  { img: condBroken, label: "チェーン切れ", desc: "切れたネックレスもそのままで" },
  { img: condTarnished, label: "黒ずみ・変色", desc: "シルバーの変色も問題なし" },
  { img: condNoStamp, label: "刻印なし", desc: "専用機器で純度を正確に測定" },
  { img: condSmall, label: "少量でも", desc: "ピアス1個・ペンダント1点からOK" },
];

// お客様の声
const voices = [
  { text: "タンスの中に眠っていたK18のネックレスやリングを5点まとめて査定していただきました。相場表通りの金額で、他社より3万円も高かったです。", who: "名古屋市千種区 60代女性" },
  { text: "エルメスのバーキンとシャネルのバッグをまとめて買取してもらいました。付属品も揃っていたので高額査定に。LINE査定で事前に相場が分かって安心でした。", who: "名古屋市中区 30代女性" },
  { text: "亡くなった母の金のブレスレットと指輪を買取してもらいました。刻印がない品もあったのですが、専用の機器で測定してくれて安心でした。", who: "名古屋市緑区 50代男性" },
];

// 金の品位解説
const purityInfo = [
  { grade: "K24(純金)", purity: "99.9%以上", feature: "非常に柔らかく、純度が高い", target: "インゴット、金貨" },
  { grade: "K22(22金)", purity: "91.7%", feature: "耐久性があり、ジュエリーにも使用", target: "一部の金貨、装飾品" },
  { grade: "K18(18金)", purity: "75.0%", feature: "耐久性と価値のバランスが良い", target: "ネックレス、指輪" },
  { grade: "K14(14金)", purity: "58.5%", feature: "比較的安価で変色しにくい", target: "ブレスレット、時計" },
  { grade: "K10(10金)", purity: "41.7%", feature: "金の割合が低く、耐久性がある", target: "カジュアルジュエリー" },
];

// ブランド買取強化
const brands = [
  { name: "エルメス", en: "HERMES" },
  { name: "シャネル", en: "CHANEL" },
  { name: "ルイ・ヴィトン", en: "LOUIS VUITTON" },
  { name: "グッチ", en: "GUCCI" },
  { name: "プラダ", en: "PRADA" },
  { name: "ディオール", en: "Dior" },
  { name: "セリーヌ", en: "CELINE" },
  { name: "ロエベ", en: "LOEWE" },
  { name: "ボッテガ・ヴェネタ", en: "BOTTEGA VENETA" },
  { name: "サンローラン", en: "SAINT LAURENT" },
  { name: "フェンディ", en: "FENDI" },
  { name: "バレンシアガ", en: "BALENCIAGA" },
];

const otherBrands = "ミュウミュウ、ジミーチュウ、ゴヤール、クロエ、フェラガモ、ジバンシー、ステラマッカートニー、ブルガリ、クリスチャンルブタン、カルティエ、ティファニー、バーバリー、ヴァレンティノ、ヴェルサーチ、クロムハーツ、MCM";
---

<Layout
  title="金・ブランド品買取 名古屋｜毎日相場更新・出張費無料の徳丸商会"
  description="名古屋の金・貴金属・ブランド品買取なら徳丸商会。金買取相場を毎日更新、K24純金からK10まで全品位対応。エルメス・シャネル・ルイヴィトンなどブランドバッグ・時計・ジュエリーも専門査定で高価買取。出張費・査定費0円、その場で現金。古物商許可業者。052-990-3968"
  extraJsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "徳丸商会トップ", "item": "https://tokumaru-shokai.com/" },
        { "@type": "ListItem", "position": 2, "name": "金・ブランド品買取", "item": "https://tokumaru-shokai.com/gold/" }
      ]
    }
  ]}
>

<!-- ═══ HEADER ═══ -->
<div class="hidden md:block fixed top-0 inset-x-0 z-50 bg-dark border-b border-gold/10">
  <div class="max-w-6xl mx-auto px-5 h-8 flex items-center justify-end gap-6 text-[11px] text-white/50">
    <span>受付 {company.hours}</span>
    <a href={`tel:${company.phone}`} class="flex items-center gap-1 text-white/70 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {company.phone}
    </a>
  </div>
</div>
<header class="fixed top-0 md:top-8 inset-x-0 z-50 bg-dark/95 backdrop-blur-md shadow-2xl border-b border-gold/15">
  <div class="max-w-6xl mx-auto px-4 md:px-5 h-[72px] md:h-[92px] flex items-center justify-between">
    <a href={homePath} class="flex items-center gap-3 group">
      <img src={logo} alt="徳丸商会" width="56" height="56" class="w-[58px] h-[58px] md:w-[72px] md:h-[72px] transition-transform group-hover:scale-105" />
      <div class="flex flex-col">
        <span class="text-white font-black text-xl md:text-2xl leading-tight tracking-tight">徳丸商会</span>
        <span class="text-gold/80 text-[9px] md:text-xs font-bold leading-tight whitespace-nowrap">金・ブランド品買取専門</span>
      </div>
    </a>
    <nav class="hidden md:flex items-center gap-1">
      <a href={sectionPath("gold-price")} class="text-white/60 hover:text-white hover:bg-white/5 text-sm font-bold px-4 py-2.5 rounded-lg transition-all">金相場</a>
      <a href={sectionPath("brand")} class="text-white/60 hover:text-white hover:bg-white/5 text-sm font-bold px-4 py-2.5 rounded-lg transition-all">ブランド品</a>
      <a href={sectionPath("flow")} class="text-white/60 hover:text-white hover:bg-white/5 text-sm font-bold px-4 py-2.5 rounded-lg transition-all">流れ</a>
      <a href={sectionPath("faq")} class="text-white/60 hover:text-white hover:bg-white/5 text-sm font-bold px-4 py-2.5 rounded-lg transition-all">FAQ</a>
    </nav>
    <div class="flex items-center gap-2">
      <a href={`tel:${company.phone}`} class="flex items-center justify-center gap-1.5 bg-gold hover:bg-gold-light text-dark font-bold text-[11px] md:text-sm px-3 md:px-5 py-2 md:py-3 rounded-lg md:rounded-xl transition-colors shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 md:w-5 md:h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        電話
      </a>
      <a href={company.line} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-1.5 bg-line hover:brightness-110 text-white font-bold text-[11px] md:text-sm px-3 md:px-5 py-2 md:py-3 rounded-lg md:rounded-xl transition-all shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 md:w-5 md:h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.630 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
        LINE
      </a>
    </div>
  </div>
</header>

<main class="pt-[72px] md:pt-[124px]">

<!-- ═══ 1. HERO ═══ -->
<section class="bg-dark text-white">
  <div class="relative hidden md:block overflow-hidden">
    <img src={hero} srcset={`${hero480} 480w, ${hero800} 800w, ${hero} 1400w`} sizes="100vw" alt="金インゴット・ジュエリー・ブランドバッグの高価買取" class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" width="1400" height="788" />
    <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/85 via-60% to-dark/30"></div>
    <div class="relative max-w-6xl mx-auto px-5 py-28 w-full">
      <div class="max-w-xl">
        <div class="inline-flex items-center gap-2 bg-gold/20 border border-gold/40 text-gold-light rounded-full px-4 py-1.5 text-xs font-bold mb-5">
          <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-gold opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-gold-light"></span></span>
          金相場高騰中 ― 今が売り時です
        </div>
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-5 mb-6 max-w-sm">
          <div class="flex items-center justify-between mb-2">
            <span class="text-white/50 text-xs font-bold">本日の金相場（K24）</span>
            <span class="text-white/30 text-[10px]">{updatedStr}</span>
          </div>
          <p class="text-gold-light font-black text-5xl leading-none mb-2">¥{fmt(goldPrice.gold.tanakaBuy)}<span class="text-xl ml-0.5">/g</span></p>
          <p class="text-white/30 text-[10px]">K18: ¥{fmt(goldPrice.gold.market.k18)}/g</p>
        </div>
        <h1 class="text-4xl lg:text-5xl font-black leading-[1.1] mb-3 tracking-tight">
          名古屋の<br><span class="text-gradient">金・ブランド品</span><br>買取なら徳丸商会
        </h1>
        <p class="text-white/80 text-base mb-8 max-w-md leading-relaxed">
          20年前の約6倍！金相場高騰中の今が売り時です。<br>出張費・査定費0円。その場で現金。
        </p>
        <div class="flex flex-wrap gap-2 mb-8">
          <span class="bg-white/10 backdrop-blur-sm text-white text-xs font-bold px-4 py-2 rounded-full border border-white/15">金相場毎日更新</span>
          <span class="bg-white/10 backdrop-blur-sm text-white text-xs font-bold px-4 py-2 rounded-full border border-white/15">手数料0円</span>
          <span class="bg-white/10 backdrop-blur-sm text-white text-xs font-bold px-4 py-2 rounded-full border border-white/15">最短即日対応</span>
          <span class="bg-white/10 backdrop-blur-sm text-white text-xs font-bold px-4 py-2 rounded-full border border-white/15">その場で現金</span>
        </div>
        <div class="flex flex-row gap-3 mb-4">
          <a href={`tel:${company.phone}`} class="cta-glow bg-gold hover:bg-gold-light text-dark font-black text-lg px-8 py-4 rounded-xl text-center transition-colors">今すぐ電話で相談する</a>
          <a href={company.line} target="_blank" rel="noopener noreferrer" class="cta-glow-line bg-line hover:brightness-110 text-white font-bold text-lg px-8 py-4 rounded-xl text-center transition-all flex items-center justify-center gap-2">
            LINEで写真査定
          </a>
        </div>
        <p class="text-white/40 text-xs">受付 {company.hours} / 出張費・査定費 0円 / キャンセル無料</p>
      </div>
    </div>
  </div>
  <!-- モバイル -->
  <div class="md:hidden bg-dark text-white">
    <div class="px-5 pt-6 pb-6">
      <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-4 mb-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-white/50 text-[10px] font-bold">本日の金相場（K24）</span>
          <span class="text-white/30 text-[9px]">{updatedStr}</span>
        </div>
        <p class="text-gold-light font-black text-3xl leading-none mb-1.5">¥{fmt(goldPrice.gold.tanakaBuy)}<span class="text-sm ml-0.5">/g</span></p>
        <p class="text-white/25 text-[8px]">K18: ¥{fmt(goldPrice.gold.market.k18)}/g</p>
      </div>
      <p class="text-[2.1rem] font-black leading-[1.15] mb-3" role="heading" aria-level="1">
        名古屋の<br><span class="text-gradient">金・ブランド品</span><br>買取なら徳丸商会
      </p>
      <p class="text-white/70 text-[13px] leading-relaxed mb-4">
        20年前の約6倍！金相場高騰中の今が売り時です。
      </p>
      <div class="flex flex-wrap gap-1.5 mb-4">
        <span class="bg-white/10 text-white text-[10px] font-bold px-2.5 py-1 rounded-full border border-white/20">金相場毎日更新</span>
        <span class="bg-white/10 text-white text-[10px] font-bold px-2.5 py-1 rounded-full border border-white/20">手数料0円</span>
        <span class="bg-white/10 text-white text-[10px] font-bold px-2.5 py-1 rounded-full border border-white/20">即日現金</span>
      </div>
      <div class="flex gap-2.5 mb-2">
        <a href={`tel:${company.phone}`} class="cta-glow flex-1 bg-gold text-dark font-black text-[13px] py-3 rounded-xl text-center shadow-lg">電話で相談する</a>
        <a href={company.line} target="_blank" rel="noopener noreferrer" class="cta-glow-line flex-1 bg-line text-white font-bold text-[13px] py-3 rounded-xl text-center shadow-lg">LINE査定</a>
      </div>
      <p class="text-white/30 text-[9px] text-center">受付 {company.hours} / 出張費・査定費0円</p>
    </div>
  </div>
</section>

<!-- ═══ 2. 信頼バー ═══ -->
<section class="border-t-4 border-gold bg-white shadow-md">
  <div class="max-w-4xl mx-auto px-5 py-6">
    <div class="grid grid-cols-3 divide-x divide-border stagger-children">
      <div class="reveal text-center px-2 md:px-4">
        <p class="text-dark font-black text-xl md:text-3xl count-up whitespace-nowrap" data-target="30000">0</p>
        <p class="text-gold font-bold text-[10px] md:text-sm">件以上</p>
        <p class="text-text-lighter text-[9px] md:text-[10px] mt-0.5 whitespace-nowrap">累計ご依頼</p>
      </div>
      <div class="reveal text-center px-2 md:px-4">
        <p class="text-dark font-black text-xl md:text-3xl count-up whitespace-nowrap" data-target="98">0</p>
        <p class="text-gold font-bold text-[10px] md:text-sm">%</p>
        <p class="text-text-lighter text-[9px] md:text-[10px] mt-0.5 whitespace-nowrap">お客様満足度</p>
      </div>
      <div class="reveal text-center px-2 md:px-4">
        <p class="text-dark font-black text-xl md:text-3xl whitespace-nowrap">0円</p>
        <p class="text-gold font-bold text-[10px] md:text-sm whitespace-nowrap">出張費・査定費</p>
        <p class="text-text-lighter text-[9px] md:text-[10px] mt-0.5 whitespace-nowrap">完全無料</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 3. お悩みセクション ═══ -->
<section class="py-12 md:py-20 bg-dark text-white">
  <div class="max-w-4xl mx-auto px-5">
    <h2 class="text-xl md:text-3xl font-black text-center mb-3 reveal">
      タンスの奥に<span class="text-gold-light">眠っていませんか？</span>
    </h2>
    <p class="text-white/60 text-sm text-center mb-10 reveal">金ネックレス・壊れたリング・ブランドバッグ・使わない時計...</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 stagger-children">
      {[
        "金の相場がよく分からない",
        "刻印がなくて他店で断られた",
        "壊れたアクセサリーも売れる？",
        "ブランド品の箱や保証書がない",
        "まとめて売りたいけど量が多い",
        "忙しくて店舗に行く時間がない",
      ].map(text => (
        <div class="reveal card-hover flex items-center gap-3 bg-white/10 backdrop-blur border border-white/20 rounded-xl p-4 text-white">
          <span class="bg-gold text-dark w-7 h-7 rounded-full flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <p class="font-bold text-sm leading-snug">{text}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-10">
      <p class="text-white font-black text-lg mb-4">その悩み、徳丸商会が全て解決します</p>
      <a href={`tel:${company.phone}`} class="cta-glow inline-block bg-gold hover:bg-gold-light text-dark font-black text-sm md:text-base px-6 md:px-8 py-3.5 md:py-4 rounded-xl shadow-xl transition-colors">電話で無料相談</a>
    </div>
  </div>
</section>

<!-- ═══ 4. 今日の金相場（タブ切り替え式） ═══ -->
<section id="gold-price" class="py-12 md:py-20 bg-bg">
  <div class="max-w-4xl mx-auto px-5">
    <div class="text-center mb-3 reveal">
      <div class="inline-block bg-gold text-dark text-[10px] md:text-xs font-bold px-4 py-1.5 rounded-full mb-4">GOLD PRICE</div>
      <h2 class="text-xl md:text-3xl font-black text-text">名古屋の金買取<br class="md:hidden" />1gあたりの参考相場表</h2>
    </div>
    <p class="text-text-light text-sm text-center mb-2 reveal">本日の金・貴金属買取相場の最新価格をチェック！<br>金・貴金属の相場は日々変動するため、以下の参考買取相場表をご確認ください。</p>
    <p class="text-text-lighter text-xs text-center mb-2 reveal">今日の金の参考買取相場</p>
    <p class="text-text-lighter text-[10px] text-center mb-6 reveal">{updatedStr} ※見出しをスクロールで選択できます。</p>

    <!-- タブ切り替え式テーブル -->
    <div class="reveal bg-white rounded-2xl shadow-md border border-border overflow-hidden mb-6" x-data="{ tab: 'gold' }">
      <!-- タブヘッダー -->
      <div class="flex border-b border-border overflow-x-auto scrollbar-hide">
        <button x-on:click="tab='gold'" x-bind:class="tab==='gold' ? 'bg-gold text-dark border-b-2 border-gold' : 'bg-bg text-text-light hover:bg-gold/10'" class="flex-1 min-w-[80px] py-3 px-4 text-sm font-black text-center transition-colors cursor-pointer whitespace-nowrap">
          金
        </button>
        <button x-on:click="tab='platinum'" x-bind:class="tab==='platinum' ? 'bg-gray-700 text-white border-b-2 border-gray-700' : 'bg-bg text-text-light hover:bg-gray-100'" class="flex-1 min-w-[80px] py-3 px-4 text-sm font-black text-center transition-colors cursor-pointer whitespace-nowrap">
          プラチナ
        </button>
        <button x-on:click="tab='silver'" x-bind:class="tab==='silver' ? 'bg-gray-400 text-white border-b-2 border-gray-400' : 'bg-bg text-text-light hover:bg-gray-100'" class="flex-1 min-w-[80px] py-3 px-4 text-sm font-black text-center transition-colors cursor-pointer whitespace-nowrap">
          シルバー
        </button>
        <button x-on:click="tab='combo'" x-bind:class="tab==='combo' ? 'bg-amber-600 text-white border-b-2 border-amber-600' : 'bg-bg text-text-light hover:bg-amber-50'" class="flex-1 min-w-[80px] py-3 px-4 text-sm font-black text-center transition-colors cursor-pointer whitespace-nowrap">
          金・プラチナ コンビ
        </button>
      </div>

      <!-- 金テーブル -->
      <div x-show="tab==='gold'" x-transition>
        <div class="divide-y divide-border">
          {goldGrades.map((g) => {
            const price = g.key === "k24"
              ? goldPrice.gold.tanakaBuy
              : goldPrice.gold.market[g.key as keyof typeof goldPrice.gold.market] as number;
            return (
              <div class="flex items-center justify-between px-5 py-3.5 hover:bg-gold/5 transition-colors">
                <span class="text-text text-sm font-bold">{g.label}</span>
                <span class="text-dark font-black text-lg md:text-xl">{fmt(price)}<span class="text-sm font-bold ml-0.5">円</span></span>
              </div>
            );
          })}
        </div>
      </div>

      <!-- プラチナテーブル -->
      <div x-show="tab==='platinum'" x-transition style="display:none">
        <div class="divide-y divide-border">
          {ptGrades.map((g) => (
            <div class="flex items-center justify-between px-5 py-3.5 hover:bg-gray-50 transition-colors">
              <span class="text-text text-sm font-bold">{g.label}</span>
              <span class="text-dark font-black text-lg md:text-xl">{fmt(g.price)}<span class="text-sm font-bold ml-0.5">円</span></span>
            </div>
          ))}
        </div>
      </div>

      <!-- シルバーテーブル -->
      <div x-show="tab==='silver'" x-transition style="display:none">
        <div class="divide-y divide-border">
          <div class="flex items-center justify-between px-5 py-3.5 hover:bg-gray-50 transition-colors">
            <span class="text-text text-sm font-bold">Sv1000(純銀)</span>
            <span class="text-dark font-black text-lg md:text-xl">{fmt(goldPrice.silver.market.sv1000)}<span class="text-sm font-bold ml-0.5">円</span></span>
          </div>
          <div class="flex items-center justify-between px-5 py-3.5 hover:bg-gray-50 transition-colors">
            <span class="text-text text-sm font-bold">Sv925(スターリングシルバー)</span>
            <span class="text-dark font-black text-lg md:text-xl">{fmt(goldPrice.silver.market.sv925)}<span class="text-sm font-bold ml-0.5">円</span></span>
          </div>
        </div>
      </div>

      <!-- 金・プラチナ コンビテーブル -->
      <div x-show="tab==='combo'" x-transition style="display:none">
        <div class="px-5 py-6 text-center">
          <p class="text-text text-sm leading-relaxed mb-2">金・プラチナのコンビ製品は、<br class="md:hidden" />それぞれの金属の重量比率に応じて査定いたします。</p>
          <p class="text-text-light text-xs">正確な買取価格は、専用機器で金属の比率を測定した上でお伝えします。</p>
          <a href={`tel:${company.phone}`} class="inline-block mt-4 bg-gold hover:bg-gold-light text-dark font-black text-sm px-6 py-3 rounded-xl transition-colors">電話でお問い合わせ</a>
        </div>
      </div>
    </div>

    <!-- シミュレーションリンク -->
    <div class="reveal text-center">
      <a href={simulationPath} class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-dark font-black text-sm md:text-base px-8 py-4 rounded-xl shadow-lg transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg>
        買取金額シミュレーション
      </a>
      <p class="text-text-lighter text-xs mt-3">品位と重量を入力するだけで概算金額がわかります</p>
    </div>
  </div>
</section>

<!-- ═══ 5. 金の品位解説 ═══ -->
<section class="py-12 md:py-20 bg-white">
  <div class="max-w-4xl mx-auto px-5">
    <h2 class="text-xl md:text-3xl font-black text-center text-text mb-3 reveal">
      純度がわからない金製品も<br class="md:hidden" />高価買取のチャンスがあります
    </h2>
